  <script>
    // --- CENTRALIZED BENEFITS DATA ---
    // 1. The main benefits displayed directly under each tier
    const coreBenefits = {
      explorer: [
        "Court reservations: $40/hr",
        "Book 3 days in advance",
        "One free Open Play Day Pass ($40 value)",
        "10% off equipment rental",
        "5% off merch, food & beverage",
        "500 bonus points at sign up",
        "1 guest pass a month",
        "🎂 Birthday: 250 bonus points"
      ],
      pioneer: [
        "Unlimited Open Play",
        "Book 5 days in advance",
        "10% off leagues, tournaments, clinics, classes",
        "1,000 bonus points at sign up",
        "2 guest passes a month",
        "🎂 Birthday: 500 pts + 10% off event room"
      ],
      trailblazer: [
        "Unlimited court reservations (up to 4 active, 2/day)",
        "Free ball machine rental once a week",
        "20% off equipment rental",
        "20% off leagues, tournaments, clinics, classes",
        "3 guest passes a month",
        "🎂 Birthday: 1,000 pts + 20% off event room"
      ]
    };

    // 2. The filtered benefits shown inside the "Includes [Tier] Benefits" dropdowns. 
    // Overlapping upgrades (like guest passes or points) have been removed here.
    const includedBenefits = {
      
      // What to show when Pioneer drops down to show Explorer:
      explorerForPioneer: [
        "Court reservations: $40/hr",
        "One free Open Play Day Pass ($40 value)",
        "10% off equipment rental",
        "5% off merch, food & beverage"
      ],
      
      // What to show when Trailblazer drops down to show Pioneer:
      pioneerForTrailblazer: [
        "Unlimited Open Play",
        "Book 5 days in advance"
      ],

      // What to show when Trailblazer drops down ALL the way to Explorer:
      // (Notice we removed the 10% equipment rental here, since Trailblazer gets 20%)
      explorerForTrailblazer: [
        "Court reservations: $40/hr",
        "One free Open Play Day Pass ($40 value)",
        "5% off merch, food & beverage"
      ]
    };

    // Helper to generate the list items
    function generateListHTML(benefitsArray) {
      return benefitsArray.map(benefit => `<div class="benefit-item">${benefit}</div>`).join('');
    }

    // Helper to generate the expandable accordion for lower tiers
    function generateAccordion(title, contentHTML) {
      return `
        <details class="group mt-3 bg-primary/5 rounded-lg">
          <summary class="flex items-center cursor-pointer list-none text-primary font-bold text-xs p-2 transition-colors hover:text-secondary rounded-lg">
            <span class="mr-2 transition-transform duration-200 group-open:rotate-90">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
            </span>
            ${title}
          </summary>
          <div class="p-3 pt-0 space-y-1.5 text-xs text-primary/70">
            ${contentHTML}
          </div>
        </details>
      `;
    }

    // Inject the benefits when the page loads
    document.addEventListener("DOMContentLoaded", () => {
      // Generate the Core Lists
      const explorerHTML = generateListHTML(coreBenefits.explorer);
      const pioneerHTML = generateListHTML(coreBenefits.pioneer);
      const trailblazerHTML = generateListHTML(coreBenefits.trailblazer);

      // Generate the Filtered Dropdown Lists
      const expForPioneerHTML = generateListHTML(includedBenefits.explorerForPioneer);
      const pioForTrailblazerHTML = generateListHTML(includedBenefits.pioneerForTrailblazer);
      const expForTrailblazerHTML = generateListHTML(includedBenefits.explorerForTrailblazer);

      document.querySelectorAll('.benefits-container').forEach(container => {
        const tier = container.getAttribute('data-tier');
        
        if (tier === 'explorer') {
          container.innerHTML = explorerHTML;
        } 
        else if (tier === 'pioneer') {
          container.innerHTML = pioneerHTML + generateAccordion('Includes Explorer Benefits', expForPioneerHTML);
        } 
        else if (tier === 'trailblazer') {
          // Trailblazer gets its own benefits + a nested accordion for Pioneer + a nested accordion for Explorer
          const nestedLowerTiersHTML = pioForTrailblazerHTML + generateAccordion('Includes Explorer Benefits', expForTrailblazerHTML);
          container.innerHTML = trailblazerHTML + generateAccordion('Includes Pioneer Benefits', nestedLowerTiersHTML);
        }
      });
    });

    // Tab switching
    function switchTab(tab) {
      document.querySelectorAll('.tab-content').forEach(el => el.classList.remove('active'));
      document.querySelectorAll('.tab-btn').forEach(el => {
        el.classList.remove('active');
        el.setAttribute('aria-selected', 'false');
        el.classList.add('text-primary/50');
        el.classList.remove('text-primary');
      });
      document.getElementById('tab-' + tab).classList.add('active');
      const activeBtn = document.querySelector('[data-tab="' + tab + '"]');
      activeBtn.classList.add('active');
      activeBtn.setAttribute('aria-selected', 'true');
      activeBtn.classList.remove('text-primary/50');
      activeBtn.classList.add('text-primary');

      // Re-trigger card animations
      document.getElementById('tab-' + tab).querySelectorAll('.plan-card').forEach((card, i) => {
        card.style.animation = 'none';
        card.offsetHeight;
        card.style.animation = 'fadeUp 0.5s ease forwards';
        card.style.animationDelay = (i * 0.1) + 's';
      });
    }

    // Demo toast
    function showDemoToast() {
      const toast = document.getElementById('demo-toast');
      toast.style.opacity = '1';
      toast.style.transform = 'translate(-50%, 0)';
      toast.style.pointerEvents = 'auto';
      setTimeout(() => {
        toast.style.opacity = '0';
        toast.style.transform = 'translate(-50%, 20px)';
        toast.style.pointerEvents = 'none';
      }, 2500);
    }
    
    // Element SDK and Icons initialization
    if (window.lucide) {
        lucide.createIcons();
    }
  </script>
